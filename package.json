{
  "name": "@stronger-ecommerce/gadget-mcp",
  "version": "1.0.11",
  "description": "Generic read-only MCP server for any Gadget app",
  "type": "module",
  "bin": {
    "gadget-mcp": "bin/gadget-mcp.js"
  },
  "files": [
    "bin",
    "dist/*.js",
    "dist/*.js.map",
    "dist/*.d.ts",
    "dist/*.d.ts.map"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev": "tsx src/index.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "gadget",
    "mcp",
    "model-context-protocol",
    "shopify"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Stronger-eCommerce/gadget-mcp"
  },
  "license": "MIT"
}
